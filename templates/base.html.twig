<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}Accueil - Le Quai-Antique
			{% endblock %}
		</title>
		<link rel="icon" href="/assets/images/Orange et Bordeaux Restaurant Logo.png">
		<meta
		name="viewport" content="width=device-width, initial-scale=1.0">

		<!-- Feuilles de styles -->
		
		<link rel="stylesheet" href="{{ asset('assets/css/bootstrap.min.css') }}"> 
		{% block stylesheets %}{% endblock %}
		<link
		rel="stylesheet" href="{{ asset('assets/css/styles.css') }}">
		<link
		rel="stylesheet" href="{{ asset('assets/css/stylecarte.css') }}">

		<!-- Fichiers JS -->
		<script src="{{ asset('assets/js/bootstrap.bundle.min.js') }}" defer></script>
		{% block javascripts %}{% endblock %}
		<script src="{{ asset('assets/js/scripts.js') }}" defer></script>
		<script src="{{ asset('assets/js/scriptcarte.js') }}" defer></script>
		<script src="{{ asset('assets/js/jQuery3.6.3.js') }}" defer></script>
		<script src="{{ asset('assets/js/turn.js') }}" defer></script>
		<script src="{{ asset('assets/js/turn.min.js') }}" defer></script>
	</head>
	<body>
		{% include "_partials/_nav.html.twig" %}


		{% if app.user and app.user.isVerified == false %}
			<div class="alert alert-warning alert-dismissible" role="alert">
				<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
				<div class="alert-message">
					<strong>Votre compte n'est pas activé</strong>,
					<a href=" {{ path('app_resend_verif') }} ">
						renvoyer le lien d'activation</a>
				</div>
			</div>
		{% endif %}

		{% include "_partials/_flash.html.twig" %}

		{% block body %}{% endblock %}

		{% include "_partials/_footer.html.twig" %}
	</body>
</html>
